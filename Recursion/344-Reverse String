// LeetCode 344
// Reverse String
// Topic: String/Recusrion
// Difficulty: Easy
// Time Complexity: O(n)
// Space Complexity: O(n)


class Solution {
    public void reverseString(char[] s) {
        int n = s.length;
        reverse(0, n - 1, s);
    }

    private void reverse(int start, int end, char[] s) {
        if (start >= end) {
            return;
        }
        char temp = s[start];
        s[start] = s[end];
        s[end] = temp;

        reverse(start + 1, end - 1, s);
    }
}
