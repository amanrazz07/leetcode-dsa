// LeetCode 231
// Power of Two (Recursion)
// Topic: Math, Recursion
// Difficulty: Easy
// Time Complexity: O(log₂ n)
// Space Complexity: O(log₂ n)

class Solution {
    public boolean isPowerOfTwo(int n){
        if(n<=0)return false;
        if(n==1)return true;
        if(n%2!=0)return false;

        return isPowerOfTwo(n/2);
    }
}
