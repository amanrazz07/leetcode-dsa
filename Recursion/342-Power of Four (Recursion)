// LeetCode 342
// Power of Four (Recursion)
// Topic: Math, Recursion
// Difficulty: Easy
// Time Complexity: O(log₄ n)
// Space Complexity: O(log₄ n)

class Solution {
    public boolean isPowerOfFour(int n){
        if(n<=0)return false;
        if(n==1)return true;
        if(n%4!=0)return false;

        return isPowerOfFour(n/4);
    }
}
