// LeetCode 136
// Single Number
// Topic: HashMap
// Difficulty: Easy
// Time Complexity: O(n)
// Space Complexity: O(n)

import java.util.*;

class Solution{
    public int singleNumber(int[]nums){
        HashMap<Integer,Integer>map=new HashMap<>();
        for(int num:nums){
            map.put(num,map.getOrDefault(num,0)+1);
        }
        for(int key:map.keySet()){
            if(map.get(key)==1){
                return key;
            }
        }
        return -1;
    }
}
