// LeetCode 509
// Fibonacci Number (Memoization)
// Topic: Dynamic Programming
// Difficulty: Easy
// Time Complexity: O(n)
// Space Complexity: O(n)

class Solution {
    public int fib(int n){
        int[]dp=new int[n+1];
        for(int i=0;i<=n;i++){
            dp[i]=-1;
        }
        return fibo(n,dp);
    }

    public static int fibo(int n,int[]dp){
        if(n<=1)return n;
        if(dp[n]!=-1)return dp[n];
        return dp[n]=fibo(n-1,dp)+fibo(n-2,dp);
    }
}
