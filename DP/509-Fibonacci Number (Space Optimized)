// LeetCode 509
// Fibonacci Number (Space Optimized)
// Topic: Dynamic Programming
// Difficulty: Easy
// Time Complexity: O(n)
// Space Complexity: O(1)

class Solution {
    public int fib(int n){
        if(n<=1)return n;

        int prev2=0;
        int prev1=1;

        for(int i=2;i<=n;i++){
            int curr=prev1+prev2;
            prev2=prev1;
            prev1=curr;
        }

        return prev1;
    }
}
