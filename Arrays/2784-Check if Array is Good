// LeetCode 2784
// Check if Array is Good
// Topic: Arrays, Sorting
// Difficulty: Easy
// Time Complexity: O(n log n)
// Space Complexity: O(1) // ignoring sorting space

import java.util.*;

class Solution {
    public boolean isGood(int[]nums){
        int n=nums.length;
        Arrays.sort(nums);

        for(int i=0;i<n-1;i++){
            if(nums[i]!=i+1){
                return false;
            }
        }

        return nums[n-1]==n-1;
    }
}
