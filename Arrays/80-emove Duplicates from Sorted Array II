// LeetCode 80
// Remove Duplicates from Sorted Array II
// Topic: Arrays, Two Pointers
// Difficulty: Medium
// Time Complexity: O(n)
// Space Complexity: O(1)

class Solution {
    public int removeDuplicates(int[]nums){
        int k=2;

        for(int i=2;i<nums.length;i++){
            if(nums[i]!=nums[k-2]){
                nums[k]=nums[i];
                k++;
            }
        }

        return k;
    }
}
