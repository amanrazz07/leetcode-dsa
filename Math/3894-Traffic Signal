// Traffic Signal
// Topic: Conditional Statements
// Difficulty: Easy
// Time Complexity: O(1)
// Space Complexity: O(1)

class Solution {
    public String trafficSignal(int t){
        if(t==0)return "Green";
        else if(t==30)return "Orange";
        else if(t>30 && t<=90)return "Red";
        return "Invalid";
    }
}
