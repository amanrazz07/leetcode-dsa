// LeetCode 231
// Power of Two (Division Approach)
// Topic: Math
// Difficulty: Easy
// Time Complexity: O(log n)
// Space Complexity: O(1)

class Solution {
    public boolean isPowerOfTwo(int n){
        if(n<=0)return false;

        while(n%2==0){
            n=n/2;
        }

        return n==1;
    }
}
