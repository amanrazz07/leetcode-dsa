// LeetCode 136
// Single Number
// Topic: Bit Manipulation (XOR)
// Difficulty: Easy
// Time Complexity: O(n)
// Space Complexity: O(1)

class Solution{
    public int singleNumber(int[]nums){
        int XOR=0;
        for(int num:nums){
            XOR^=num;
        }
        return XOR;
    }
}
